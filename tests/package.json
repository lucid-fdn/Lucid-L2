{
  "name": "lucid-l2-tests",
  "version": "1.0.0",
  "description": "Production-ready test suite for Lucid L2 onchain programs",
  "scripts": {
    "test": "mocha -r ts-node/register '*.test.ts' --timeout 60000",
    "test:thought-epoch": "mocha -r ts-node/register 'thought-epoch-complete.test.ts' --timeout 60000",
    "test:gas-utils": "mocha -r ts-node/register 'gas-utils-complete.test.ts' --timeout 60000",
    "test:passports": "mocha -r ts-node/register 'lucid-passports-complete.test.ts' --timeout 60000",
    "test:integration": "mocha -r ts-node/register 'integration/**/*.test.ts' --timeout 120000",
    "test:devnet": "mocha -r ts-node/register 'devnet/**/*.test.ts' --timeout 120000"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.3.8",
    "@solana/web3.js": "^1.87.6",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
