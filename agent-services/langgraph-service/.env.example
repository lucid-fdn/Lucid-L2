# LangGraph Executor Service Configuration

# OpenAI API Key (required for LangChain/LangGraph)
OPENAI_API_KEY=your_openai_api_key_here

# TrustGate inference gateway
TRUSTGATE_URL=https://trustgate-api-production.up.railway.app
TRUSTGATE_API_KEY=your_trustgate_api_key_here

# Lucid API URL (for Solana operations)
LUCID_API_URL=http://host.docker.internal:3001

# Service Port
PORT=8083

# Environment
ENVIRONMENT=development
