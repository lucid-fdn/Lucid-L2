# LangGraph Executor Service Configuration

# OpenAI API Key (required for LangChain/LangGraph)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Proxy URL (optional, for alternative LLM providers)
LLM_PROXY_URL=http://host.docker.internal:8001

# Lucid API URL (for Solana operations)
LUCID_API_URL=http://host.docker.internal:3001

# Service Port
PORT=8083

# Environment
ENVIRONMENT=development
