{
  "name": "github",
  "type": "data",
  "description": "GitHub API via MCP protocol",
  "version": "1.0.0",
  "status": "available",
  "operations": [
    {
      "name": "createIssue",
      "description": "Create a GitHub issue",
      "parameters": {
        "repo": "string",
        "title": "string",
        "body": "string",
        "labels": "string[] (optional)"
      }
    },
    {
      "name": "searchRepos",
      "description": "Search GitHub repositories",
      "parameters": {
        "query": "string",
        "limit": "number (optional, default: 10)"
      }
    },
    {
      "name": "getFile",
      "description": "Get file contents from repo",
      "parameters": {
        "repo": "string",
        "path": "string",
        "branch": "string (optional, default: main)"
      }
    }
  ],
  "port": 9004,
  "protocol": "mcp",
  "authentication": "token"
}
