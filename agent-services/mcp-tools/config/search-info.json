{
  "name": "web-search",
  "type": "data",
  "description": "Web search via MCP protocol (Brave Search)",
  "version": "1.0.0",
  "status": "available",
  "operations": [
    {
      "name": "search",
      "description": "Search the web",
      "parameters": {
        "query": "string",
        "limit": "number (optional, default: 10)",
        "freshness": "string (optional: day|week|month)"
      }
    },
    {
      "name": "news",
      "description": "Search news articles",
      "parameters": {
        "query": "string",
        "limit": "number (optional, default: 10)"
      }
    }
  ],
  "port": 9005,
  "protocol": "mcp",
  "authentication": "api_key",
  "provider": "Brave Search"
}
