{
  "name": "ipfs",
  "type": "storage",
  "description": "IPFS decentralized storage via MCP protocol",
  "version": "1.0.0",
  "status": "available",
  "operations": [
    {
      "name": "upload",
      "description": "Upload content to IPFS",
      "parameters": {
        "content": "string",
        "filename": "string"
      }
    },
    {
      "name": "pin",
      "description": "Pin content by CID",
      "parameters": {
        "cid": "string"
      }
    },
    {
      "name": "get",
      "description": "Retrieve content by CID",
      "parameters": {
        "cid": "string"
      }
    }
  ],
  "port": 9002,
  "protocol": "mcp",
  "authentication": "none"
}
