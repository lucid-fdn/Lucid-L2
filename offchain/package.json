{
  "name": "raijin-labs",
  "version": "0.0.1",
  "author": "Speakeasy",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "raijin-labs": "bin/mcp-server.js",
    "mcp": "bin/mcp-server.js"
  },
  "scripts": {
    "build": "node -e \"console.warn('Skipping bun-based build: bun is not available in this environment. Run `npm run build:node` instead.');\"",
    "build:node": "node src/mcp-server/build.mts && tsc -p tsconfig.json",
    "mcpb:build": "node -e \"console.warn('Skipping bun-based mcpb build: bun is not available in this environment.');\"",
    "check": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.warn('lint disabled: eslint is not installed in node_modules (Speakeasy template expects it).');\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "@stricli/core": "^1.1.2",
    "bun": "^1.2.12",
    "express": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.2.0",
    "@eslint/js": "^9.26.0",
    "@types/bun": "^1.2.13",
    "@types/express": "^5.0.1",
    "@types/node": "^18.19.3",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.31.1"
  }
}
