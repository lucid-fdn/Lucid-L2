{
  "name": "lucid-offchain-mvp",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "cli": "ts-node src/cli.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start:pm2": "pm2 start npm --name \"lucid-offchain\" -- start"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@elastic/elasticsearch": "^8.11.1",
    "@irys/upload": "^0.0.15",
    "@irys/upload-solana": "^0.1.8",
    "@nangohq/node": "^0.69.10",
    "@nktkas/hyperliquid": "^0.25.9",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-express": "^0.60.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/instrumentation-pg": "^0.64.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@privy-io/node": "^0.3.0",
    "@privy-io/server-auth": "^1.32.5",
    "@raijinlabs/passport": "file:./local-packages/passport",
    "@sentry/node": "^10.39.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.95.0",
    "@supabase/supabase-js": "^2.80.0",
    "@types/pg": "^8.15.6",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.12.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "elliptic": "^6.6.1",
    "ethers": "^6.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "json-canonicalize": "^2.0.0",
    "openai": "^5.10.1",
    "p-limit": "^3.1.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "tweetnacl": "^1.0.3",
    "ulid": "^3.0.2",
    "viem": "^2.46.2"
  },
  "optionalDependencies": {
    "@lighthouse-web3/sdk": "^0.3.0",
    "@metaplex-foundation/mpl-core": "^1.1.0",
    "@metaplex-foundation/umi": "^0.9.0",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.0",
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bn.js": "^5.2.0",
    "@types/elliptic": "^6.4.18",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.24",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "commander": "^9.5.0",
    "express-openapi-validator": "^5.6.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/packages"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ]
  }
}
