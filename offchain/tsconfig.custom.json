{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noPropertyAccessFromIndexSignature": false,
    "strict": true
  },
  "include": [
    "src/providers/**/*.ts",
    "src/routes/**/*.ts",
    "src/services/**/*.ts",
    "src/middleware/**/*.ts",
    "src/protocols/**/*.ts",
    "src/solana/**/*.ts",
    "src/storage/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/funcs",
    "src/models",
    "src/mcp-server",
    "src/hooks",
    "src/sdk.ts",
    "src/index.ts",
    "src/lib"
  ]
}
