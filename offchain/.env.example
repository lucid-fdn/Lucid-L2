# =============================================================================
# LUCID L2 OFFCHAIN API - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Sentry — error tracking & performance monitoring
# Leave blank to disable Sentry (safe for local dev).
SENTRY_DSN=

# OpenTelemetry — distributed tracing
# Set to "true" to enable OTel trace collection.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Environment identifier used by both Sentry and OTel.
# Typical values: development, staging, production
LUCID_ENV=development

# =============================================================================
# TRUSTGATE
# =============================================================================

# TrustGate inference gateway (OpenAI-compatible)
TRUSTGATE_URL=https://trustgate-api-production.up.railway.app
TRUSTGATE_API_KEY=your_tenant_api_key

# Control-plane admin key (X-Admin-Key header, for tenant/key management)
TRUSTGATE_ADMIN_KEY=your_admin_key

# =============================================================================
# HUGGINGFACE
# =============================================================================

# HuggingFace API token for model/dataset/space discovery sync
HF_TOKEN=your_huggingface_token

# =============================================================================
# DEPIN STORAGE (Decentralized permanent/evolving file storage)
# =============================================================================

# Permanent storage provider (epoch proofs, NFT metadata, attestations)
# Options: 'arweave' (production — Irys bundler), 'mock' (dev/test)
DEPIN_PERMANENT_PROVIDER=mock

# Evolving storage provider (agent memory, mutable metadata)
# Options: 'lighthouse' (production — Filecoin+IPFS), 'mock' (dev/test)
DEPIN_EVOLVING_PROVIDER=mock

# Kill switch — set to 'false' to disable all DePIN uploads globally.
# Default: enabled (any value other than 'false' means enabled).
DEPIN_UPLOAD_ENABLED=true

# --- Arweave / Irys (required when DEPIN_PERMANENT_PROVIDER=arweave) ---
# Sign up: https://irys.xyz — fund with SOL on devnet or mainnet.
# Network: 'devnet' (free, testnet) or 'mainnet' (real SOL cost).
IRYS_NETWORK=devnet
IRYS_TOKEN=solana
# Ed25519 private key (base58 or JSON array) for signing Irys uploads.
# Generate: solana-keygen new --no-bip39-passphrase -o irys-key.json
IRYS_PRIVATE_KEY=

# --- Lighthouse (required when DEPIN_EVOLVING_PROVIDER=lighthouse) ---
# Sign up: https://files.lighthouse.storage — free tier: 5 GB.
# Get API key from dashboard after email verification.
LIGHTHOUSE_API_KEY=

# =============================================================================
# SOLANA
# =============================================================================

# Orchestrator signing key for receipts + epoch anchoring (Ed25519)
# Generate: solana-keygen new --no-bip39-passphrase -o orchestrator.json
# Then base64-encode: cat orchestrator.json | base64
# LUCID_ORCHESTRATOR_SECRET_KEY=your_base64_or_json_keypair

# Solana RPC endpoints
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Solana private key for transaction signing (base58 or JSON byte array)
# Generate: solana-keygen new --no-bip39-passphrase -o wallet.json
# SOLANA_PRIVATE_KEY=
# Or path to Anchor wallet file:
# ANCHOR_WALLET=~/.config/solana/id.json

# =============================================================================
# SOLANA PROGRAM IDS (defaults point to devnet deployments)
# =============================================================================

# Core epoch commitment program
# THOUGHT_EPOCH_PROGRAM_ID=9YhfaLoUZYLzu3xRQevRom4qj8oTf5TGpuoWptvStKDu

# Passport NFT registry (Token-2022 + x402 payment gating)
# PASSPORTS_PROGRAM_ID=FhoemNdqwPMt8nmX4HT3WpSqUuqeAUXRb7WchAehmSaL

# Gas burn/split utility
# GAS_UTILS_PROGRAM_ID=EzuUhxtNAz1eRfAPypm6eAepe8fRQBrBPSo4Qcp1w3hm

# Agent wallet (PDA wallets, policy, escrow, splits, sessions)
# AGENT_WALLET_PROGRAM_ID=AJGpTWXbhvdYMxSah6GAKzykvfkYo2ViQpWGMbimQsph

# zkML Groth16 proof verifier (bloom filter dedup, model registry)
# ZKML_VERIFIER_PROGRAM_ID=69cJRFGWijD1FdapQ2vz7VP6x2jcXRQyBws9VzzPpqAN

# =============================================================================
# ANCHORING PIPELINE
# =============================================================================

# Set to 'true' to disable real Solana anchoring (local dev)
# ANCHORING_MOCK_MODE=true

# How often to check for finalizable epochs (ms, default 60000)
# EPOCH_FINALIZATION_INTERVAL_MS=60000

# How often to run the anchoring job (ms, default 600000 = 10 min)
# ANCHORING_JOB_INTERVAL_MS=600000

# Multi-chain epoch anchoring (comma-separated chain IDs)
# Default: solana-devnet (backward compatible)
# Example: solana-devnet,base-sepolia,apechain-testnet
ANCHORING_CHAINS=solana-devnet

# =============================================================================
# EVM CHAINS
# =============================================================================

# RPC URLs (defaults use public RPCs, override for production)
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# APECHAIN_TESTNET_RPC_URL=https://rpc.curtis.apechain.com/http

# EVM private key for transaction signing (hex, with 0x prefix)
# EVM_PRIVATE_KEY=0x...

# =============================================================================
# DATABASE (PostgreSQL — optional, falls back to in-memory)
# =============================================================================

# PostgreSQL connection string for receipt/epoch persistence
# DATABASE_URL=postgresql://user:password@localhost:5432/lucid

# Agent Mirror (cross-DB sync from platform-core)
# Required for agentMirrorConsumer to poll agent_created_events
# PLATFORM_CORE_DB_URL=postgresql://user:password@localhost:5432/lucid_platform
