# =============================================================================
# Dockerfile for worker-gpu-vllm (Fluid Compute v0 — Pass A)
# Multi-stage build: compile TypeScript with full deps, then slim runtime image
#
# Build context: Lucid-L2/
# Usage:
#   VERSION="1.0.0-$(git rev-parse --short HEAD)"
#   docker build -f Dockerfile.worker-gpu-vllm -t lucidlayer/worker-gpu-vllm:$VERSION .
# =============================================================================

# ===========================================================================
# STAGE 1: Build — compile TypeScript with ALL dependencies
# ===========================================================================
FROM node:20-slim AS builder

WORKDIR /build

# Install dependencies (ALL — including devDependencies for tsc)
COPY offchain/package.json offchain/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

# Copy TypeScript config and source
COPY offchain/tsconfig.json ./tsconfig.json
COPY offchain/src/ ./src/

# Compile TypeScript → dist/
# noEmitOnError defaults to false, so JS is emitted even with type errors
# from unrelated files (routes, services that aren't needed by the worker)
RUN npx tsc --outDir dist --rootDir src || true

# Verify the worker entry point was compiled
RUN test -f dist/workers/worker-gpu-vllm/index.js \
    && echo "✅ Worker compiled successfully" \
    || (echo "❌ Worker compilation failed — check imports" && exit 1)

# Prune to production-only node_modules
RUN npm prune --omit=dev 2>/dev/null || true

# ===========================================================================
# STAGE 2: Runtime — NVIDIA CUDA base with vLLM + Node.js
# ===========================================================================
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    curl wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Node.js 20 LTS
# ---------------------------------------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# vLLM + PyTorch (GPU)
# ---------------------------------------------------------------------------
RUN pip3 install --no-cache-dir vllm torch transformers

# ---------------------------------------------------------------------------
# App directory
# ---------------------------------------------------------------------------
WORKDIR /app

# ---------------------------------------------------------------------------
# Copy compiled JS + production node_modules from builder
# ---------------------------------------------------------------------------
COPY --from=builder /build/dist/ ./dist/
COPY --from=builder /build/node_modules/ ./node_modules/
COPY --from=builder /build/package.json ./package.json

# ---------------------------------------------------------------------------
# Copy entrypoint script
# ---------------------------------------------------------------------------
COPY offchain/src/workers/worker-gpu-vllm/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# ---------------------------------------------------------------------------
# Create model cache and log directories
# ---------------------------------------------------------------------------
RUN mkdir -p /models /var/log

# ---------------------------------------------------------------------------
# Environment defaults
# ---------------------------------------------------------------------------
ENV NODE_ENV=production
ENV WORKER_PORT=8080
ENV VLLM_PORT=8000
ENV VLLM_HOST=localhost
ENV VLLM_MODEL_DIR=/models

# ---------------------------------------------------------------------------
# Expose ports
# ---------------------------------------------------------------------------
EXPOSE 8080

# ---------------------------------------------------------------------------
# Health check
# ---------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# ---------------------------------------------------------------------------
# Start via entrypoint (starts vLLM + worker)
# ---------------------------------------------------------------------------
CMD ["/entrypoint.sh"]