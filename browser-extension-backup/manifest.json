{
  "manifest_version": 3,
  "name": "Lucid L2™ - AI Thought Miner",
  "version": "1.0.0",
  "description": "Earn mGas by interacting with AI models in the Lucid L2™ ecosystem",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://api.lucid-l2.com/*",
    "https://api.devnet.solana.com/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lucid L2™ AI Thought Miner"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "wallet-connection.js", "devnet-transaction-handler.js", "solana-web3.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
