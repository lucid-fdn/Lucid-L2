<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lucid L2™ AI Thought Miner</title>
    <link rel="stylesheet" href="popup-styles.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="logo">
                <img src="icons/icon48.png" alt="Lucid L2™" class="logo-icon">
                <h1>Lucid L2™</h1>
            </div>
            <div class="header-info">
                <button class="btn-pin" id="pinBtn" title="Open in new window">📌</button>
                <div class="version">v1.0.0</div>
                <div class="network-indicator devnet" id="networkIndicator">DEVNET</div>
            </div>
        </header>

        <!-- Quick Stats Banner -->
        <section class="quick-stats" id="quickStats">
            <div class="stat-card">
                <div class="stat-icon">⚡</div>
                <div class="stat-content">
                    <div class="stat-label">mGas</div>
                    <div class="stat-value" id="statMGas">0</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💎</div>
                <div class="stat-content">
                    <div class="stat-label">LUCID</div>
                    <div class="stat-value" id="statLUCID">0</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🎯</div>
                <div class="stat-content">
                    <div class="stat-label">Daily</div>
                    <div class="stat-value" id="statDaily">0/10</div>
                </div>
            </div>
        </section>

        <!-- Tab Navigation -->
        <nav class="tab-nav">
            <button class="tab-btn active" data-tab="dashboard">
                <span class="tab-icon">🏠</span>
                <span class="tab-label">Dashboard</span>
            </button>
            <button class="tab-btn" data-tab="activity">
                <span class="tab-icon">📊</span>
                <span class="tab-label">Activity</span>
            </button>
            <button class="tab-btn" data-tab="settings">
                <span class="tab-icon">⚙️</span>
                <span class="tab-label">Settings</span>
            </button>
        </nav>

        <!-- Tab Content Container -->
        <div class="tab-content-container">
            <!-- Dashboard Tab -->
            <div class="tab-content active" id="dashboard-tab">
                <!-- Wallet Connection Section -->
                <section class="wallet-section" id="walletSection">
                    <div class="wallet-status" id="walletStatus">
                        <div class="wallet-disconnected" id="walletDisconnected">
                            <div class="section-icon">💼</div>
                            <h3>Connect Your Wallet</h3>
                            <p>Connect your Solana wallet to start earning mGas</p>
                            <button class="btn btn-primary" id="connectWalletBtn">Connect Wallet</button>
                        </div>
                        <div class="wallet-connected hidden" id="walletConnected">
                            <div class="wallet-info">
                                <div class="wallet-header">
                                    <span class="wallet-badge">Connected</span>
                                    <button class="btn btn-small btn-secondary" id="disconnectWalletBtn">Disconnect</button>
                                </div>
                                <div class="wallet-address" id="walletAddress">
                                    <span class="address-label">Address:</span>
                                    <span class="address-text" id="addressText">Not connected</span>
                                    <button class="btn btn-icon" id="copyAddressBtn" title="Copy address">📋</button>
                                </div>
                                <div class="balance-grid">
                                    <div class="balance-item">
                                        <span class="balance-label">SOL</span>
                                        <span class="balance-value" id="solBalance">0</span>
                                    </div>
                                    <div class="balance-item">
                                        <span class="balance-label">mGas</span>
                                        <span class="balance-value" id="mGasBalance">0</span>
                                    </div>
                                    <div class="balance-item">
                                        <span class="balance-label">$LUCID</span>
                                        <span class="balance-value" id="lucidBalance">0</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- AI Interaction Section -->
                <section class="ai-section" id="aiSection">
                    <div class="section-header">
                        <h3>💭 AI Thought Mining</h3>
                        <div class="progress-indicator">
                            <span id="dailyProgress">0/10</span>
                            <div class="progress-bar">
                                <div class="progress-fill" id="progressFill"></div>
                            </div>
                        </div>
                    </div>

                    <div class="ai-interaction">
                        <div class="input-group">
                            <textarea 
                                id="aiInput" 
                                placeholder="Enter your thought or question for AI processing..."
                                rows="3"
                                maxlength="500"
                            ></textarea>
                            <div class="input-footer">
                                <span class="char-count" id="charCount">0/500</span>
                                <button class="btn btn-primary" id="processBtn" disabled>
                                    Process Thought
                                </button>
                            </div>
                        </div>

                        <div class="ai-response hidden" id="aiResponse">
                            <div class="response-header">
                                <h4>AI Response</h4>
                                <div class="gas-earned">
                                    +<span id="gasEarned">0</span> mGas
                                </div>
                            </div>
                            <div class="response-content" id="responseContent"></div>
                            <div class="quality-info" id="qualityInfo"></div>
                            <div class="response-actions">
                                <button class="btn btn-small" id="shareBtn">📤 Share</button>
                                <button class="btn btn-small" id="shareAdvancedBtn">✨ Share+</button>
                                <button class="btn btn-small" id="saveBtn">💾 Save</button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Quick Actions -->
                <section class="quick-actions">
                    <button class="action-card" id="convertBtn">
                        <span class="action-icon">💰</span>
                        <span class="action-label">Convert to LUCID</span>
                    </button>
                    <button class="action-card" id="achievementsBtn">
                        <span class="action-icon">🏆</span>
                        <span class="action-label">Achievements</span>
                    </button>
                    <button class="action-card" id="leaderboardBtn">
                        <span class="action-icon">📊</span>
                        <span class="action-label">Leaderboard</span>
                    </button>
                </section>
            </div>

            <!-- Activity Tab -->
            <div class="tab-content" id="activity-tab">
                <!-- Daily Tasks -->
                <section class="section">
                    <div class="section-header">
                        <h3>✅ Daily Tasks</h3>
                        <div class="streak-badge">
                            🔥 <span id="streakCount">0</span> day streak
                        </div>
                    </div>
                    <div class="tasks-list" id="tasksList"></div>
                </section>

                <!-- Recent Activity -->
                <section class="section">
                    <div class="section-header">
                        <h3>📝 Recent Activity</h3>
                        <button class="btn btn-small" id="viewAllBtn">View All</button>
                    </div>
                    <div class="history-list" id="historyList"></div>
                </section>

                <!-- ChatGPT Captures -->
                <section class="section">
                    <div class="section-header">
                        <h3>🤖 ChatGPT Captures</h3>
                    </div>
                    <div class="chatgpt-captures-list" id="chatgptCapturesList"></div>
                </section>

                <!-- Active Events -->
                <section class="section">
                    <div class="section-header">
                        <h3>🎉 Active Events</h3>
                    </div>
                    <div class="events-list" id="eventsList"></div>
                </section>
            </div>

            <!-- Settings Tab -->
            <div class="tab-content" id="settings-tab">
                <section class="section">
                    <h3>⚙️ Settings</h3>
                    
                    <div class="settings-group">
                        <h4>Notifications</h4>
                        <div class="setting-item">
                            <label class="setting-label">
                                <input type="checkbox" id="notificationsToggle" checked>
                                <span>Enable notifications</span>
                            </label>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">
                                <input type="checkbox" id="autoProcessToggle">
                                <span>Auto-process highlighted text</span>
                            </label>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4>Data Management</h4>
                        <div class="setting-item">
                            <button class="btn btn-secondary" id="resetDataBtn">🗑️ Reset Extension Data</button>
                            <p class="setting-description">Clear all local data and reset to defaults</p>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4>Information</h4>
                        <div class="info-links">
                            <a href="#" id="helpLink" class="info-link">❓ Help & Support</a>
                            <a href="#" id="aboutLink" class="info-link">ℹ️ About Lucid L2</a>
                            <a href="#" id="privacyLink" class="info-link">🔒 Privacy Policy</a>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div class="loading-overlay hidden" id="loadingOverlay">
        <div class="spinner"></div>
        <div class="loading-text">Processing...</div>
    </div>

    <!-- Toast Notification -->
    <div class="toast hidden" id="toast">
        <div class="toast-content" id="toastContent"></div>
        <button class="toast-close" id="toastClose">×</button>
    </div>

    <script src="config.js"></script>
    <script src="reward-system.js"></script>
    <script src="privy-api-bridge.js"></script>
    <script src="popup.js"></script>
</body>
</html>
