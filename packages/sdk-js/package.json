{
  "name": "@lucidlayer/sdk",
  "version": "1.0.0",
  "deprecated": "Use @lucid-l2/sdk instead",
  "description": "TypeScript SDK for LucidLayer - Decentralized AI Compute Orchestration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "generate:openapi": "openapi-ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lucidlayer",
    "ai",
    "llm",
    "inference",
    "compute",
    "passport",
    "solana",
    "blockchain",
    "decentralized"
  ],
  "author": "LucidLayer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucidlayer/lucid-l2"
  },
  "bugs": {
    "url": "https://github.com/lucidlayer/lucid-l2/issues"
  },
  "homepage": "https://lucidlayer.io",
  "dependencies": {
    "eventsource-parser": "^1.1.2"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.85.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
