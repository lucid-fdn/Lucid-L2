# n8n Configuration
# Copy this file to .env and fill in the values

# n8n Basic Auth
N8N_USER=admin
N8N_PASSWORD=<CHANGE-ME-STRONG-PASSWORD>

# n8n Encryption Key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=<GENERATE-32-CHAR-HEX-KEY>

# HMAC Secret for API → n8n authentication (generate with: openssl rand -hex 32)
N8N_HMAC_SECRET=<GENERATE-32-CHAR-HEX-KEY>

# Database Password
DB_PASSWORD=<CHANGE-ME-POSTGRES-PASSWORD>

# Quick Setup Commands:
# 1. Generate encryption key:
#    openssl rand -hex 32
# 2. Generate HMAC secret:
#    openssl rand -hex 32
# 3. Copy this file:
#    cp .env.example .env
# 4. Edit .env and paste the generated keys
# 5. Start n8n:
#    docker compose up -d
