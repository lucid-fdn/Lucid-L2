# AI Documentation Pipeline — Environment Variables
# Copy to .env and fill in values

# TrustGate (Lucid's own inference gateway — preferred)
TRUSTGATE_URL=https://trustgate-api-production.up.railway.app
TRUSTGATE_API_KEY=lk_your_raijinlabs_internal_key

# Model for AI enrichment (routed through TrustGate)
DOCS_MODEL=gpt-4o

# Fallback: Direct OpenAI (only if TrustGate unavailable)
# OPENAI_API_KEY=sk-...
