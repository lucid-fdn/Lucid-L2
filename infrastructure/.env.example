# =============================================================================
# LUCID OAUTH INFRASTRUCTURE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# Generate secrets with: openssl rand -hex 32

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Database
SUPABASE_DB_PASSWORD=your-super-secret-database-password-change-me

# JWT Configuration (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-me
JWT_EXPIRY=3600

# Supabase API Keys (generate with scripts/generate-keys.sh)
# These are base64 encoded JWTs with specific roles
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Public URLs
SUPABASE_PUBLIC_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# Additional Redirect URLs (comma-separated)
ADDITIONAL_REDIRECT_URLS=

# Signup Configuration
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP Configuration (for email notifications)
SMTP_ADMIN_EMAIL=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password
SMTP_SENDER_NAME=Lucid OAuth

# Email Templates
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# PostgREST Configuration
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Image Transformation
IMGPROXY_ENABLE_WEBP_DETECTION=true

# =============================================================================
# NANGO OAUTH SERVER CONFIGURATION
# =============================================================================

# Server URL (change to your production domain when deploying)
NANGO_SERVER_URL=http://localhost:3003
# For production: https://oauth.yourdomain.com

# Nango Secret Key (generate with: openssl rand -hex 32)
NANGO_SECRET_KEY=your-nango-secret-key-min-32-chars-change-me

# Nango Public Key (get from Nango dashboard after first run)
NANGO_PUBLIC_KEY=

# =============================================================================
# PRIVY AUTHENTICATION (for your separate frontend app)
# =============================================================================

# Get these from https://dashboard.privy.io
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# =============================================================================
# OAUTH API SERVICE CONFIGURATION
# =============================================================================

# API Server Port
OAUTH_API_PORT=3004

# Frontend App URL (for CORS and redirects)
FRONTEND_APP_URL=http://localhost:3000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Set to 'production' when deploying
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Enable debug mode
DEBUG=false
