{
  "manifest_version": 3,
  "name": "Lucid-Extension",
  "version": "1.0.0",
  "description": "AI Thought Mining extension for Lucid L2™ - Earn mGas by interacting with AI models.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "identity", "activeTab", "alarms", "notifications", "contextMenus", "scripting"],
  "host_permissions": [
    "https://*.privy.io/*",
    "https://auth.privy.io/*", 
    "https://api.privy.io/*",
    "https://auth-api.privy.io/*",
    "https://chatgpt.com/*", 
    "https://chat.openai.com/*",
    "http://localhost:3001/*",
    "http://172.28.35.139:3001/*",
    "https://api.lucid-l2.com/*",
    "https://api.devnet.solana.com/*",
    "https://api.testnet.solana.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://*.walletconnect.org/*",
    "https://*.walletconnect.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "icons/*", "dist/*", "auth.html", "auth-redirect.js", "privy-api-bridge.js", "injected.js"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lucid-Extension - AI Thought Mining"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; object-src 'self'; connect-src 'self' http: https: ws: wss: data:; frame-ancestors 'none';"
  }
}
