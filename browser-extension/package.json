{
  "name": "Lucid-Extension",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:clean && npm run build:auth && npm run build:bridge",
    "build:clean": "rm -rf dist && mkdir -p dist",
    "build:auth": "BUILD_TARGET=auth vite build",
    "build:bridge": "BUILD_TARGET=bridge vite build --emptyOutDir=false",
    "watch": "BUILD_TARGET=auth vite build --watch",
    "watch:bridge": "BUILD_TARGET=bridge vite build --watch --emptyOutDir=false"
  },
  "dependencies": {
    "@privy-io/react-auth": "^2.25.0",
    "@solana-program/system": "^0.7.0",
    "@solana-program/token": "^0.6.0",
    "@solana/kit": "^2.3.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.20"
  }
}
